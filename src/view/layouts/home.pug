include ../config/config
block config

doctype html
html(lang='en')

  head
    meta(charset='utf-8')
    meta(name='viewport' content='width=device-width, initial-scale=1, shrink-to-fit=no')

    meta(name='author' content='Pirulug')

    meta(name='robots' content='index, follow')

    meta(name='theme-color' content='#0d6efd')

    // Primary Meta Tags
    title #{pageName} - Free Bootstrap 5 Admin Template | #{siteName}
    meta(name='title' content=`${pageName} - Free Bootstrap 5 Admin Template | ${siteName}`)

    meta(name='description' content=`${siteName} is a modern, open-source Bootstrap 5 Admin Dashboard. Features flat UI, dark mode, 800+ components, and vanilla JS. Perfect for your next SaaS.`)

    meta(name='keywords' content='bootstrap 5, admin dashboard, admin template, flat ui, dark mode, vanilla js, open source, dashboard template, scss')

    link(rel='canonical' href=`https://pirulug.github.io/piruadmin-bootstrap-5-dashboard/${pageUrl}.html`)

    // Open Graph / Facebook
    meta(property='og:type' content='website')
    meta(property='og:url' content=`https://pirulug.github.io/piruadmin-bootstrap-5-dashboard/${pageUrl}.html`)
    meta(property='og:title' content=`${pageName} | ${siteName}`)
    meta(property='og:description' content='Download the best free Bootstrap 5 Admin Dashboard with a clean, flat design and dark mode support.')
    meta(property='og:image' content='https://pirulug.github.io/piruadmin-bootstrap-5-dashboard/img/background.png')

    // Twitter
    meta(property='twitter:card' content='summary_large_image')
    meta(property='twitter:url' content=`https://pirulug.github.io/piruadmin-bootstrap-5-dashboard/${pageUrl}.html`)
    meta(property='twitter:title' content=`${pageName} | ${siteName}`)
    meta(property='twitter:description' content='Modern Bootstrap 5 Admin Dashboard. Flat design, no jQuery, ready for production.')
    meta(property='twitter:image' content='https://pirulug.github.io/piruadmin-bootstrap-5-dashboard/img/background.png')

    meta(property='twitter:creator' content='@pirulug')

    // Favicon
    link(rel='apple-touch-icon' sizes='180x180' href=assets + 'img/favicon/apple-touch-icon.png')
    link(rel='icon' type='image/png' sizes='32x32' href=assets + 'img/favicon/favicon-32x32.png')
    link(rel='icon' type='image/png' sizes='16x16' href=assets + 'img/favicon/favicon-16x16.png')
    link(rel='manifest' href=assets + 'img/favicon/site.webmanifest')

    // Core theme CSS (includes Bootstrap)
    link(rel="stylesheet" href=assets + "plugins/fontawesome.css")
    link(href=assets + 'css/piruadmin.css' rel='stylesheet')

    link(rel='preload' href=assets + 'css/piruadmin.css' as='style')

    //- 5. SCHEMA.ORG (JSON-LD): Esto ayuda a Google a entender que es un "Software"
    script(type='application/ld+json').
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "#{siteName}",
        "operatingSystem": "Web",
        "applicationCategory": "DeveloperApplication",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        },
        "description": "Premium Bootstrap 5 Admin Dashboard featuring flat UI design and dark mode.",
        "author": {
          "@type": "Person",
          "name": "Pirulug"
        }
      }

    script.
      (function () {
        const storedTheme = localStorage.getItem('theme');
        const prefersDarkScheme = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = storedTheme || (prefersDarkScheme ? 'dark' : 'light');
        document.documentElement.setAttribute('data-bs-theme', theme);
      })();

  body

    include ../includes/home-nav

    block header

    .github-corner
      a(href='https://github.com/pirulug/piruadmin-bootstrap-5-dashboard' target='_blank' aria-label='View on GitHub')
        i(data-feather='github')

    block content

    include ../includes/home-footer

    // Dark & Ligth
    include ../includes/dark-ligth

    // Core theme JS
    script(src=assets + 'plugins/feathericons.js')
    script(src=assets + 'js/piruadmin.js')


    block scripts