extends ../../layouts/dashboard

append config
  - pageName = 'PiruAwesome Icons'
  - pageUrl = 'icons/piruawesome'

block styles
  link(rel="stylesheet" href=assets + "plugins/piruawesome.css")

block scripts
  script.
    document.addEventListener("DOMContentLoaded", () => {
        // Data injected from PUG
        const rawData = !{JSON.stringify(piruiconsawesome)};
        
        // DOM Elements
        const searchInput = document.getElementById("icon-search");
        const styleFilters = document.querySelectorAll(".style-filter");
        const iconsContainer = document.getElementById("icons-container");
        const emptyState = document.getElementById("icons-empty-state");
        const loadMoreSentinel = document.getElementById("load-more-sentinel");

        // State management
        let currentStyle = "all";
        let searchQuery = "";
        let flatData = []; // Normalized list for filtering
        let filteredData = [];
        let currentIndex = 0;
        const chunkSize = 100;

        // Flatten data for easier processing
        function flattenData() {
            flatData = [];
            for (const [style, icons] of Object.entries(rawData)) {
                icons.forEach(name => {
                    flatData.push({ name, style });
                });
            }
        }

        function filterData() {
            filteredData = flatData.filter(item => {
                const matchesSearch = item.name.toLowerCase().includes(searchQuery);
                const matchesStyle = currentStyle === "all" || item.style === currentStyle;
                return matchesSearch && matchesStyle;
            });
            
            // Reset rendering
            currentIndex = 0;
            iconsContainer.innerHTML = "";
            renderNextChunk();
            
            if (emptyState) {
                emptyState.style.display = filteredData.length === 0 ? "block" : "none";
            }
        }

        const iconModalElement = document.getElementById('iconModal');
        const modal = new bootstrap.Modal(iconModalElement);
        const modalIconPreview = document.getElementById('modalIconPreview');
        const modalIconName = document.getElementById('modalIconName');
        const htmlCodeInput = document.getElementById('htmlCodeInput');
        const pugCodeInput = document.getElementById('pugCodeInput');

        function createIconElement(item) {
            const col = document.createElement("div");
            col.className = "col-6 col-md-4 col-lg-2 icon-item-container";
            col.dataset.name = item.name;
            col.dataset.style = item.style;
            
            col.innerHTML = `
                <div class="card h-100 text-center  p-4 border-0" style="cursor: pointer;">
                    <i class="pr pr-${item.style} pr-${item.name} mb-3" style="font-size: 1.75rem;"></i>
                    <span class="small text-muted text-break">${item.name}</span>
                </div>
            `;
            return col;
        }

        function renderNextChunk() {
            if (currentIndex >= filteredData.length) return;
            
            const fragment = document.createDocumentFragment();
            const nextBatch = filteredData.slice(currentIndex, currentIndex + chunkSize);
            
            nextBatch.forEach(item => {
                fragment.appendChild(createIconElement(item));
            });
            
            iconsContainer.appendChild(fragment);
            currentIndex += chunkSize;
        }

        // Initialize Observer
        const observer = new IntersectionObserver((entries) => {
            if (entries[0].isIntersecting) {
                renderNextChunk();
            }
        }, { rootMargin: "200px" });

        if (loadMoreSentinel) {
            observer.observe(loadMoreSentinel);
        }

        // Event Listeners
        if (searchInput) {
            searchInput.addEventListener("input", (e) => {
                searchQuery = e.target.value.toLowerCase().trim();
                filterData();
            });
        }

        styleFilters.forEach(filter => {
            filter.addEventListener("click", (e) => {
                e.preventDefault();
                styleFilters.forEach(f => f.classList.remove("active", "btn-primary"));
                styleFilters.forEach(f => f.classList.add("btn-outline-primary"));
                filter.classList.add("active", "btn-primary");
                filter.classList.remove("btn-outline-primary");
                
                currentStyle = filter.dataset.filter;
                filterData();
            });
        });

        // Copy to clipboard (Event Delegation)
        iconsContainer.addEventListener("click", (e) => {
            const item = e.target.closest(".card");
            if (!item) return;

            const iconElement = item.querySelector("i");
            const iconName = item.querySelector("span").innerText;
            const iconClass = Array.from(iconElement.classList).filter(c => !["align-middle", "me-2", "mb-3"].includes(c)).join(" ");
            
            modalIconName.innerText = iconName;
            htmlCodeInput.value = `<i class="${iconClass}"></i>`;
            pugCodeInput.value = `i(class="${iconClass}")`;
            modalIconPreview.innerHTML = `<i class="${iconClass}" style="font-size: 3rem;"></i>`;
            
            modal.show();
        });

        // Modal Copy Buttons
        document.querySelectorAll('.copy-modal-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const targetId = btn.getAttribute('data-target');
                const input = document.getElementById(targetId);
                input.select();
                try {
                    document.execCommand('copy');
                    const originalText = btn.innerText;
                    btn.innerText = 'Copied!';
                    btn.classList.replace('btn-outline-secondary', 'btn-success');
                    setTimeout(() => {
                        btn.innerText = originalText;
                        btn.classList.replace('btn-success', 'btn-outline-secondary');
                    }, 1500);
                } catch (err) {
                    console.error('Failed to copy', err);
                }
            });
        });

        // Initialize
        flattenData();
        filterData();
    });

block content
  .card.mb-4
    .card-header.d-flex.align-items-center.justify-content-between
      div
        h3.card-title Pirulug Icons Awesome
        h6.card-subtitle.text-muted A professional, multi-style icon library with over 1000+ icons.
      a.btn.btn-dark.btn-sm(href="https://github.com/pirulug/pirulug-icons-awesome" target="_blank")
        i.fab.fa-github.me-2
        | GitHub Repo
    .card-body
      .row.align-items-center
        .col-md-6.mb-3.mb-md-0
          .input-group
            span.input-group-text.bg-transparent.border-end-0
              i.fa.fa-search.text-muted
            input#icon-search.form-control.border-start-0(type="text" placeholder="Buscar iconos (ej. user, home, arrow)...")
        .col-md-6
          .d-flex.flex-wrap.gap-2.justify-content-md-end
            button.btn.btn-primary.style-filter.active(data-filter="all") Todos
            if piruiconsawesome.solid
              button.btn.btn-outline-primary.style-filter(data-filter="solid") Solid
            if piruiconsawesome.regular
              button.btn.btn-outline-primary.style-filter(data-filter="regular") Regular
            if piruiconsawesome.light
              button.btn.btn-outline-primary.style-filter(data-filter="light") Light
            if piruiconsawesome.thin
              button.btn.btn-outline-primary.style-filter(data-filter="thin") Thin
            if piruiconsawesome.brands
              button.btn.btn-outline-primary.style-filter(data-filter="brands") Brands

  #icons-container.row.g-3
    // Icons will be rendered dynamically here

  #load-more-sentinel.text-center.py-4
    .spinner-border.spinner-border-sm.text-primary(role="status")
      span.visually-hidden Cargando...

  #icons-empty-state.text-center.py-5(style="display: none;")
    i.fa.fa-search.mb-3(style="font-size: 3rem; color: var(--pr-secondary-bg);")
    h4 No se encontraron iconos
    p.text-muted Intenta con otra palabra clave o estilo.

  // Icon Modal
  #iconModal.modal.fade(tabindex='-1' aria-labelledby='iconModalLabel' aria-hidden='true')
    .modal-dialog.modal-dialog-centered
      .modal-content
        .modal-header
          h5#iconModalLabel.modal-title Detalles del Icono
          button.btn-close(type='button' data-bs-dismiss='modal' aria-label='Close')
        .modal-body
          .text-center.mb-4
            #modalIconPreview.mb-2
            h4#modalIconName.text-primary
          
          .mb-3
            label.form-label Código HTML
            .input-group
              input#htmlCodeInput.form-control(type='text' readonly)
              button.btn.btn-outline-secondary.copy-modal-btn(type='button' data-target='htmlCodeInput') Copiar
          
          .mb-0
            label.form-label Código PUG
            .input-group
              input#pugCodeInput.form-control(type='text' readonly)
              button.btn.btn-outline-secondary.copy-modal-btn(type='button' data-target='pugCodeInput') Copiar

