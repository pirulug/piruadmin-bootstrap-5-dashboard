extends ../../layouts/auth

append config
  - pageName = 'Reset Password'
  - pageUrl = 'pages-reset-password'

block content
  .d-flex.min-vh-100.align-items-center.justify-content-center.py-4
    .container
      .row.justify-content-center
        .col-12.col-sm-9.col-md-7.col-lg-5.col-xl-4

          .text-center.mb-4
            .auth-logo-box.d-inline-flex.align-items-center.justify-content-center.text-white.rounded-3.mb-3(style="width: 44px; height: 44px;")
              i.fa-solid.fa-envelope
            h5.fw-bold.mb-1 Forgot Password?
            p.text-body-secondary.small Enter your email and we'll send you a reset link.

          .card.auth-card.border-0.rounded-3
            .card-body.p-4

              form
                .mb-4
                  label.form-label.fw-semibold.small(for='inputEmail') Email Address
                  input#inputEmail.form-control(
                    type='email' 
                    name='email' 
                    placeholder='Enter your email'
                  )

                .d-grid
                  a.btn.btn-primary(href='/') Send Reset Link

          .text-center.mt-3
            p.text-body-secondary.small.mb-0
              | Suddenly remembered? 
              a.fw-semibold.text-decoration-none.auth-footer-link(href=baseUrl + 'auth/sign-in.html') Sign In