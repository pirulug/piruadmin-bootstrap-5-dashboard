      .collapse#collapseTagifyReadonly.mt-3
        .demo-code-preview(data-label='CODE EXAMPLE')
          button.copy-btn(type='button') Copy
          pre.language-js
            code.language-js.
              new Tagify(document.querySelector('input[name=readonly]'), {
                readonly: true
              });

  // =====================================================
  // Max tags limit
  // =====================================================
  .card
    .card-header
      h3.header-title Max tags
    .card-body
      p.text-secondary
        | Limits the number of tags using
        code maxTags: 3
        | .
      input.form-control(
        name="max"
        placeholder="Maximum 3 tags allowed"
      )
      .text-center.mt-3
        button.btn.btn-sm.btn-outline-secondary(type='button' data-bs-toggle='collapse' data-bs-target='#collapseTagifyMax' aria-expanded='false' aria-controls='collapseTagifyMax')
