      .collapse#collapseTagifyEnforce.mt-3
        .demo-code-preview(data-label='CODE EXAMPLE')
          button.copy-btn(type='button') Copy
          pre.language-js
            code.language-js.
              new Tagify(document.querySelector('input[name=enforce]'), {
                whitelist: ['Admin', 'Editor', 'User'],
                enforceWhitelist: true,
                dropdown: {
                  enabled: 0
                }
              });

  // =====================================================
  // Readonly tags
  // =====================================================
  .card.mb-3
    .card-header
      h3.header-title Readonly
    .card-body
      p.text-secondary
        | Read-only Tagify input using
        code readonly: true
        | .
      input.form-control(
        name="readonly"
