        name="enforce"
        placeholder="Select a role"
      )
      .text-center.mt-3
        button.btn.btn-sm.btn-outline-secondary(type='button' data-bs-toggle='collapse' data-bs-target='#collapseTagifyEnforce' aria-expanded='false' aria-controls='collapseTagifyEnforce')
          i.bi.bi-code-slash.me-1
