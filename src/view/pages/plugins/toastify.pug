extends ../../layouts/dashboard

append config
  - pageName = 'Toastify JS'
  - pageUrl = 'plugins/toastify'

block styles
  link(rel="stylesheet", href=assets + "css/toastifyjs.css")
  link(rel="stylesheet", href=assets + "css/prismjs.css")

block content
  .row.g-3
    // Basic
    .col-md-6
      .card
        .card-body
          h5.card-title Basic Toast
          p.text-muted A simple, clean notification toast with default behavior and styling.
          .pt-4.pb-4.text-center
            button#toast-basic.btn.btn-primary(type='button')
              i.bi.bi-lightning-charge.me-1
              | Show Basic Toast
          .text-center.mt-2
            button.btn.btn-sm.btn-outline-secondary(type='button' data-bs-toggle='collapse' data-bs-target='#collapseBasic' aria-expanded='false' aria-controls='collapseBasic')
              i.bi.bi-code-slash.me-1
              | View Code
          .collapse#collapseBasic.mt-3
            .demo-code-preview(data-label='CODE EXAMPLE')
              button.copy-btn(type='button') Copy
              pre.language-js
                code.language-js.
                  Toastify({
                    text: "This is a toast",
                    duration: 3000
                  }).showToast();

    // Success
    .col-md-6
      .card
        .card-body
          h5.card-title Success Toast
          p.text-muted A success-themed notification featuring a custom gradient background and a close button.
          .pt-4.pb-4.text-center
            button#toast-success.btn.btn-success(type='button')
              i.bi.bi-check-circle.me-1
              | Show Success Toast
          .text-center.mt-2
            button.btn.btn-sm.btn-outline-secondary(type='button' data-bs-toggle='collapse' data-bs-target='#collapseSuccess' aria-expanded='false' aria-controls='collapseSuccess')
              i.bi.bi-code-slash.me-1
              | View Code
          .collapse#collapseSuccess.mt-3
            .demo-code-preview(data-label='CODE EXAMPLE')
              button.copy-btn(type='button') Copy
              pre.language-js
                code.language-js.
                  Toastify({
                    text: "This is a success toast",
                    duration: 3000,
                    close: true,
                    gravity: "top", // `top` or `bottom`
                    position: "right", // `left`, `center` or `right`
                    stopOnFocus: true, // Prevents dismissing of toast on hover
                    style: {
                      background: "linear-gradient(to right, #00b09b, #96c93d)",
                    }
                  }).showToast();

    // Error
    .col-md-6
      .card
        .card-body
          h5.card-title Error Toast
          p.text-muted An error-themed notification with high-contrast styling to alert users about failures.
          .pt-4.pb-4.text-center
            button#toast-error.btn.btn-danger(type='button')
              i.bi.bi-x-circle.me-1
              | Show Error Toast
          .text-center.mt-2
            button.btn.btn-sm.btn-outline-secondary(type='button' data-bs-toggle='collapse' data-bs-target='#collapseError' aria-expanded='false' aria-controls='collapseError')
              i.bi.bi-code-slash.me-1
              | View Code
          .collapse#collapseError.mt-3
            .demo-code-preview(data-label='CODE EXAMPLE')
              button.copy-btn(type='button') Copy
              pre.language-js
                code.language-js.
                  Toastify({
                    text: "This is an error toast",
                    duration: 3000,
                    close: true,
                    gravity: "top",
                    position: "right",
                    style: {
                      background: "linear-gradient(to right, #ff5f6d, #ffc371)",
                    }
                  }).showToast();

    // Custom Position
    .col-md-6
      .card
        .card-body
          h5.card-title Bottom Left
          p.text-muted Demonstrates custom positioning logic by placing the toast in the bottom-left corner of the viewport.
          .pt-4.pb-4.text-center
            button#toast-bottom-left.btn.btn-info(type='button')
              i.bi.bi-info-circle.me-1
              | Bottom Left Toast
          .text-center.mt-2
            button.btn.btn-sm.btn-outline-secondary(type='button' data-bs-toggle='collapse' data-bs-target='#collapseBottomLeft' aria-expanded='false' aria-controls='collapseBottomLeft')
              i.bi.bi-code-slash.me-1
              | View Code
          .collapse#collapseBottomLeft.mt-3
            .demo-code-preview(data-label='CODE EXAMPLE')
              button.copy-btn(type='button') Copy
              pre.language-js
                code.language-js.
                  Toastify({
                    text: "This is a bottom-left toast",
                    duration: 3000,
                    gravity: "bottom",
                    position: "left",
                    style: {
                      background: "linear-gradient(to right, #0072ff, #00c6ff)",
                    }
                  }).showToast();

block scripts
  script(src=assets + "js/toastifyjs.js")
  script(src=assets + "js/prismjs.js")

  script.
    document.getElementById("toast-basic").addEventListener("click", () => {
      Toastify({
        text: "This is a toast",
        duration: 3000
      }).showToast();
    });

    document.getElementById("toast-success").addEventListener("click", () => {
      Toastify({
        text: "This is a success toast",
        duration: 3000,
        close: true,
        gravity: "top",
        position: "right",
        stopOnFocus: true,
        style: {
          background: "linear-gradient(to right, #00b09b, #96c93d)",
        }
      }).showToast();
    });

    document.getElementById("toast-error").addEventListener("click", () => {
      Toastify({
        text: "This is an error toast",
        duration: 3000,
        close: true,
        gravity: "top",
        position: "right",
        style: {
          background: "linear-gradient(to right, #ff5f6d, #ffc371)",
        }
      }).showToast();
    });

    document.getElementById("toast-bottom-left").addEventListener("click", () => {
      Toastify({
        text: "This is a bottom-left toast",
        duration: 3000,
        gravity: "bottom",
        position: "left",
        style: {
          background: "linear-gradient(to right, #0072ff, #00c6ff)",
        }
      }).showToast();
    });

  script.
    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const code = btn.nextElementSibling?.innerText;
        if (!code) return;

        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(code).then(() => {
            showCopySuccess(btn);
          }).catch(err => {
            console.error('Clipboard API failed', err);
            fallbackCopy(code, btn);
          });
        } else {
          fallbackCopy(code, btn);
        }
      });
    });

    function fallbackCopy(text, btn) {
      const textarea = document.createElement('textarea');
      textarea.value = text;
      textarea.style.position = 'fixed';
      textarea.style.opacity = '0';
      document.body.appendChild(textarea);
      textarea.focus();
      textarea.select();

      try {
        const successful = document.execCommand('copy');
        if (successful) {
          showCopySuccess(btn);
        } else {
          alert("No se pudo copiar el texto");
        }
      } catch (err) {
        console.error('Fallback copy failed', err);
        alert("Error al copiar");
      }

      document.body.removeChild(textarea);
    }

    function showCopySuccess(btn) {
      const original = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(() => {
        btn.textContent = original;
      }, 1500);
    }
