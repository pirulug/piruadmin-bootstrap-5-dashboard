          article#breadcrumb.my-3
            .bd-heading.align-self-start.mt-5.mb-3.mt-xl-0.mb-xl-2
              h3 Breadcrumb
              a.d-flex.align-items-center(href='../components/breadcrumb/') Documentation
            div
              .bd-example-snippet.bd-code-snippet
                .bd-example
                  nav(aria-label='breadcrumb')
                    ol.breadcrumb
                      li.breadcrumb-item
                        a(href='#') Home
                      li.breadcrumb-item
                        a(href='#') Library
                      li.breadcrumb-item.active(aria-current='page') Data
          article#buttons.my-3
            .bd-heading.align-self-start.mt-5.mb-3.mt-xl-0.mb-xl-2
              h3 Buttons
              a.d-flex.align-items-center(href='../components/buttons/') Documentation
            div
              .bd-example-snippet.bd-code-snippet
                .bd-example
