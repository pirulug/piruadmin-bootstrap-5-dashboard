                      tr.table-primary
                        th(scope='row') Primary
                        td Cell
                        td Cell
                      tr.table-secondary
                        th(scope='row') Secondary
                        td Cell
                        td Cell
                      tr.table-success
                        th(scope='row') Success
                        td Cell
                        td Cell
                      tr.table-danger
                        th(scope='row') Danger
                        td Cell
                        td Cell
                      tr.table-warning
                        th(scope='row') Warning
                        td Cell
                        td Cell
                      tr.table-info
                        th(scope='row') Info
                        td Cell
                        td Cell
                      tr.table-light
                        th(scope='row') Light
                        td Cell
                        td Cell
                      tr.table-dark
                        th(scope='row') Dark
                        td Cell
                        td Cell
              .bd-example-snippet.bd-code-snippet
                .bd-example
                  table.table.table-sm.table-bordered
                    thead
                      tr
                        th(scope='col') #
                        th(scope='col') First
                        th(scope='col') Last
                        th(scope='col') Handle
                    tbody
                      tr
                        th(scope='row') 1
                        td Mark
                        td Otto
                        td @mdo
                      tr
                        th(scope='row') 2
                        td Jacob
                        td Thornton
                        td @fat
                      tr
                        th(scope='row') 3
                        td(colspan='2') Larry the Bird
                        td @twitter
          article#figures.my-3
            .bd-heading.align-self-start.mt-5.mb-3.mt-xl-0.mb-xl-2
              h3 Figures
              a.d-flex.align-items-center(href='../content/figures/') Documentation
            div
              .bd-example-snippet.bd-code-snippet
                .bd-example
                  figure.figure.m-0
                    .rounded.bg-dark.bg-opacity-10.d-flex.align-items-center.justify-content-center(style='height: 300px; width: 400px;')
                      i.bi.bi-camera.fs-1.text-muted
                    figcaption.figure-caption.mt-2 A caption for the above image representation.
        section#forms
          h2.fw-bold.pt-3.pt-xl-5.pb-2.pb-xl-3 Form Elements
          article#overview.my-3
            .bd-heading.align-self-start.mt-5.mb-3.mt-xl-0.mb-xl-2
              h3 Overview
              a.d-flex.align-items-center(href='https://getbootstrap.com/docs/5.3/forms/overview/' target='_blank') Documentation
            div
              .card.mb-4
                .card-body.p-4
                  form
                    .row.g-3
                      .col-md-6
                        label.form-label Email address
                        input.form-control(type='email' placeholder='name@example.com')
                        .form-text Standard email input field.
                      .col-md-6
                        label.form-label Password
                        input.form-control(type='password' placeholder='••••••••')
                      .col-12
                        label.form-label Selection
                        select.form-select
                          option(selected='') Choose an option...
                          option(value='1') Feature One
                          option(value='2') Feature Two
                      .col-12
                        .form-check.form-switch
                          input#switchDemo.form-check-input(type='checkbox' role='switch' checked='')
                          label.form-check-label(for='switchDemo') Enable notifications
                      .col-12
                        button.btn.btn-primary.px-4(type='submit') 
                          i.bi.bi-send.me-2
                          | Submit Form
          article#disabled-forms.my-3
            .bd-heading.align-self-start.mt-5.mb-3.mt-xl-0.mb-xl-2
              h3 Disabled forms
              a.d-flex.align-items-center(href='../forms/overview/#disabled-forms') Documentation
            div
              .bd-example-snippet.bd-code-snippet
                .bd-example
                  form
                    fieldset(disabled='' aria-label='Disabled fieldset example')
                      .mb-3
                        label.form-label(for='disabledTextInput') Disabled input
                        input#disabledTextInput.form-control(type='text' placeholder='Disabled input')
                      .mb-3
                        label.form-label(for='disabledSelect') Disabled select menu
                        select#disabledSelect.form-select
                          option Disabled select
                      .mb-3
                        .form-check
                          input#disabledFieldsetCheck.form-check-input(type='checkbox' disabled='')
                          label.form-check-label(for='disabledFieldsetCheck')
                            | Can&apos;t check this
                      fieldset.mb-3
                        legend Disabled radios buttons
                        .form-check
                          input#disabledRadio1.form-check-input(type='radio' name='radios' disabled='')
                          label.form-check-label(for='disabledRadio1') Disabled radio
                        .mb-3.form-check
                          input#disabledRadio2.form-check-input(type='radio' name='radios' disabled='')
                          label.form-check-label(for='disabledRadio2') Another radio
                      .mb-3
                        label.form-label(for='disabledCustomFile') Upload
                        input#disabledCustomFile.form-control(type='file' disabled='')
                      .mb-3.form-check.form-switch
                        input#disabledSwitchCheckChecked.form-check-input(type='checkbox' role='switch' checked='' disabled='')
                        label.form-check-label(for='disabledSwitchCheckChecked') Disabled checked switch checkbox input
                      .mb-3
                        label.form-label(for='disabledRange') Disabled range
                        input#disabledRange.form-range(type='range' min='0' max='5' step='0.5')
                      button.btn.btn-primary(type='submit') Submit
          article#sizing.my-3
            .bd-heading.align-self-start.mt-5.mb-3.mt-xl-0.mb-xl-2
              h3 Sizing & Feedback
              a.d-flex.align-items-center(href='https://getbootstrap.com/docs/5.3/forms/form-control/#sizing' target='_blank') Documentation
            div
              .row.g-3
                .col-md-6
                  input.form-control.form-control-lg(type='text' placeholder='Large Input (.form-control-lg)')
                .col-md-6
                  input.form-control.form-control-sm(type='text' placeholder='Small Input (.form-control-sm)')
          article#input-group.my-3
            .bd-heading.align-self-start.mt-5.mb-3.mt-xl-0.mb-xl-2
              h3 Input group
              a.d-flex.align-items-center(href='../forms/input-group/') Documentation
            div
              .bd-example-snippet.bd-code-snippet
                .bd-example
                  .input-group.mb-3
                    span#basic-addon1.input-group-text @
                    input.form-control(type='text' placeholder='Username' aria-label='Username' aria-describedby='basic-addon1')
                  .input-group.mb-3
                    input.form-control(type='text' placeholder="Recipient's username" aria-label="Recipient's username" aria-describedby='basic-addon2')
                    span#basic-addon2.input-group-text @example.com
                  label.form-label(for='basic-url') Your vanity URL
                  .input-group.mb-3
                    span#basic-addon3.input-group-text https://example.com/users/
                    input#basic-url.form-control(type='text' aria-describedby='basic-addon3')
                  .input-group.mb-3
                    span.input-group-text $
                    input.form-control(type='text' aria-label='Amount (to the nearest dollar)')
                    span.input-group-text .00
                  .input-group
                    span.input-group-text With textarea
                    textarea.form-control(aria-label='With textarea')
          article#floating-labels.my-3
            .bd-heading.align-self-start.mt-5.mb-3.mt-xl-0.mb-xl-2
              h3 Floating labels
              a.d-flex.align-items-center(href='../forms/floating-labels/') Documentation
            div
              .bd-example-snippet.bd-code-snippet
                .bd-example
                  form
                    .form-floating.mb-3
                      input#floatingInput.form-control(type='email' placeholder='name@example.com')
                      label(for='floatingInput') Email address
                    .form-floating
                      input#floatingPassword.form-control(type='password' placeholder='Password')
                      label(for='floatingPassword') Password
          article#validation.my-3
            .bd-heading.align-self-start.mt-5.mb-3.mt-xl-0.mb-xl-2
              h3 Validation
              a.d-flex.align-items-center(href='../forms/validation/') Documentation
            div
              .bd-example-snippet.bd-code-snippet
                .bd-example
                  form.row.g-3
                    .col-md-4
                      label.form-label(for='validationServer01') First name
                      input#validationServer01.form-control.is-valid(type='text' value='Mark' required='')
                      .valid-feedback
                        | Looks good!
                    .col-md-4
                      label.form-label(for='validationServer02') Last name
                      input#validationServer02.form-control.is-valid(type='text' value='Otto' required='')
                      .valid-feedback
                        | Looks good!
                    .col-md-4
                      label.form-label(for='validationServerUsername') Username
                      .input-group.has-validation
                        span#inputGroupPrepend3.input-group-text @
                        input#validationServerUsername.form-control.is-invalid(type='text' aria-describedby='inputGroupPrepend3' required='')
                        .invalid-feedback
                          | Please choose a username.
                    .col-md-6
                      label.form-label(for='validationServer03') City
                      input#validationServer03.form-control.is-invalid(type='text' required='')
                      .invalid-feedback
                        | Please provide a valid city.
                    .col-md-3
                      label.form-label(for='validationServer04') State
                      select#validationServer04.form-select.is-invalid(required='')
                        option(selected='' disabled='' value='') Choose...
                        option ...
                      .invalid-feedback
                        | Please select a valid state.
                    .col-md-3
                      label.form-label(for='validationServer05') Zip
                      input#validationServer05.form-control.is-invalid(type='text' required='')
                      .invalid-feedback
                        | Please provide a valid zip.
                    .col-12
                      .form-check
                        input#invalidCheck3.form-check-input.is-invalid(type='checkbox' value='' required='')
                        label.form-check-label(for='invalidCheck3')
                          | Agree to terms and conditions
                        .invalid-feedback
                          | You must agree before submitting.
                    .col-12
                      button.btn.btn-primary(type='submit') Submit form
        section#components
          h2.fw-bold.pt-3.pt-xl-5.pb-2.pb-xl-3 Components
          article#accordion.my-3
            .bd-heading.align-self-start.mt-5.mb-3.mt-xl-0.mb-xl-2
              h3 Accordion
              a.d-flex.align-items-center(href='https://getbootstrap.com/docs/5.3/components/accordion/' target='_blank') Documentation
            div
              #accordionExample.accordion
                .accordion-item
                  h2#headingOne.accordion-header
                    button.accordion-button(type='button' data-bs-toggle='collapse' data-bs-target='#collapseOne' aria-expanded='true' aria-controls='collapseOne')
                      i.bi.bi-info-circle.me-2
                      | Getting Started
                  #collapseOne.accordion-collapse.collapse.show(aria-labelledby='headingOne' data-bs-parent='#accordionExample')
                    .accordion-body
                      strong Welcome to the interface guide.
                      |  This accordion demonstrates how to present collapsible information in a clean, organized manner. It's perfect for FAQs or detailed documentation sections.
                .accordion-item
                  h2#headingTwo.accordion-header
                    button.accordion-button.collapsed(type='button' data-bs-toggle='collapse' data-bs-target='#collapseTwo' aria-expanded='false' aria-controls='collapseTwo')
                      i.bi.bi-command.me-2
                      | Advanced Features
                  #collapseTwo.accordion-collapse.collapse(aria-labelledby='headingTwo' data-bs-parent='#accordionExample')
                    .accordion-body
                      | Explore the full potential of our design system with these advanced components and layout utilities designed for high-performance applications.
          
          article#alerts.my-3
            .bd-heading.align-self-start.mt-5.mb-3.mt-xl-0.mb-xl-2
              h3 Alerts
              a.d-flex.align-items-center(href='https://getbootstrap.com/docs/5.3/components/alerts/' target='_blank') Documentation
            div
              .row.g-3
                .col-md-6
                  .alert.alert-primary.alert-dismissible.fade.show.border-0(role='alert')
                    strong.me-2
                      i.bi.bi-info-circle-fill
                    | New system update available!
                    button.btn-close(type='button' data-bs-dismiss='alert' aria-label='Close')
                .col-md-6
                  .alert.alert-success.alert-dismissible.fade.show.border-0(role='alert')
                    strong.me-2
                      i.bi.bi-check-circle-fill
                    | Action completed successfully.
                    button.btn-close(type='button' data-bs-dismiss='alert' aria-label='Close')
                .col-12
                  .alert.alert-warning.d-flex.align-items-center.border-0(role='alert')
                    i.bi.bi-exclamation-triangle-fill.fs-4.me-3
                    div
                      | Please ensure you have backed up your data before proceeding with the migration.
          article#badge.my-3
            .bd-heading.align-self-start.mt-5.mb-3.mt-xl-0.mb-xl-2
