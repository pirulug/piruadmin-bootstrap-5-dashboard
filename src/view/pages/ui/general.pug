extends ../../layouts/dashboard

append config
  -pageName = 'General Ui'
  - pageUrl = 'ui/general'

block styles
  style.
    aside{
      position: sticky;
      top:1rem;
    }

block content

  .row.g-4
    .col-lg-3
      aside.sticky-top(style='top: 1.5rem; height: calc(100vh - 3rem);')
        .card.h-100
          .card-header.bg-transparent.py-3
            h6.fw-bold.mb-0 On this page
          .card-body.p-0
            .list-group.list-group-flush.rounded-0(style='height: calc(100vh - 8rem); overflow-y: auto; overflow-x: hidden;')
              // Foundational Section
              .p-3.pb-2
                span.text-uppercase.fw-bold.text-muted.small Foundation
              a.list-group-item.list-group-item-action.border-0.px-3(href='#typography') 
                i.bi.bi-type.me-2
                | Typography
              a.list-group-item.list-group-item-action.border-0.px-3(href=baseUrl + 'ui/images.html') 
                i.bi.bi-image.me-2
                | Images
              a.list-group-item.list-group-item-action.border-0.px-3(href=baseUrl + 'ui/avatar.html') 
                i.bi.bi-person-circle.me-2
                | Avatars
              a.list-group-item.list-group-item-action.border-0.px-3(href='#tables') 
                i.bi.bi-table.me-2
                | Tables
              a.list-group-item.list-group-item-action.border-0.px-3(href='#figures') 
                i.bi.bi-image-fill.me-2
                | Figures

              // Forms Section
              .p-3.pb-2.pt-4
                span.text-uppercase.fw-bold.text-muted.small Form Elements
              a.list-group-item.list-group-item-action.border-0.px-3(href='#overview') 
                i.bi.bi-input-cursor.me-2
                | Overview
              a.list-group-item.list-group-item-action.border-0.px-3(href='#sizing') 
                i.bi.bi-aspect-ratio.me-2
                | Sizing & Feedback
              a.list-group-item.list-group-item-action.border-0.px-3(href='#floating-labels') 
                i.bi.bi-chat-dots.me-2
                | Floating Labels

              // Components Section
              .p-3.pb-2.pt-4
                span.text-uppercase.fw-bold.text-muted.small Components
              a.list-group-item.list-group-item-action.border-0.px-3(href='#accordion') 
                i.bi.bi-view-stacked.me-2
                | Accordion
              a.list-group-item.list-group-item-action.border-0.px-3(href='#alerts') 
                i.bi.bi-exclamation-octagon.me-2
                | Alerts
              a.list-group-item.list-group-item-action.border-0.px-3(href='#badge') 
                i.bi.bi-award.me-2
                | Badge
              a.list-group-item.list-group-item-action.border-0.px-3(href='#buttons') 
                i.bi.bi-mouse2.me-2
                | Buttons
              a.list-group-item.list-group-item-action.border-0.px-3(href='#card') 
                i.bi.bi-card-heading.me-2
                | Cards
              a.list-group-item.list-group-item-action.border-0.px-3(href='#navbar') 
                i.bi.bi-list.me-2
                | Navigation
              a.list-group-item.list-group-item-action.border-0.px-3(href='#pagination') 
                i.bi.bi-123.me-2
                | Pagination
              a.list-group-item.list-group-item-action.border-0.px-3(href='#progress') 
                i.bi.bi-bar-chart-steps.me-2
                | Progress & Loaders
              a.list-group-item.list-group-item-action.border-0.px-3.mb-3(href='#tooltips') 
                i.bi.bi-info-circle.me-2
                | Tips & Popovers

    .col-lg-9
      section#content
        h2.fw-bold.pb-2 Contents
        article#typography.my-3
          .bd-heading.align-self-start.mt-5.mb-3.mt-xl-0.mb-xl-2
            h3 Typography
            a.d-flex.align-items-center(href='https://getbootstrap.com/docs/5.3/content/typography/' target='_blank') Documentation
          div
              .bd-example-snippet.bd-code-snippet
                .bd-example
                  p.display-1 Display 1
                  p.display-2 Display 2
                  p.display-3 Display 3
                  p.display-4 Display 4
                  p.display-5 Display 5
                  p.display-6 Display 6
              .bd-example-snippet.bd-code-snippet
                .bd-example
                  p.h1 Heading 1
                  p.h2 Heading 2
                  p.h3 Heading 3
                  p.h4 Heading 4
                  p.h5 Heading 5
                  p.h6 Heading 6
              .bd-example-snippet.bd-code-snippet
                .bd-example
                  p.lead
                    | This is a lead paragraph. It stands out from regular paragraphs.
              .bd-example-snippet.bd-code-snippet
                .bd-example
                  p
                    | You can use the mark tag to
                    mark highlight
                    |                   text.
                  p
                    del This line of text is meant to be treated as deleted text.
                  p
                    s This line of text is meant to be treated as no longer accurate.
                  p
                    ins This line of text is meant to be treated as an addition to the document.
                  p
                    u This line of text will render as underlined.
                  p
                    small This line of text is meant to be treated as fine print.
                  p
                    strong This line rendered as bold text.
                  p
                    em This line rendered as italicized text.
              .bd-example-snippet.bd-code-snippet
                .bd-example
                  hr
              .bd-example-snippet.bd-code-snippet
                .bd-example
                  blockquote.blockquote
                    p A well-known quote, contained in a blockquote element.
                    footer.blockquote-footer
                      | Someone famous in
                      cite(title='Source Title') Source Title
              .bd-example-snippet.bd-code-snippet
                .bd-example
                  ul.list-unstyled
                    li This is a list.
                    li It appears completely unstyled.
                    li Structurally, it&apos;s still a list.
                    li However, this style only applies to immediate child elements.
                    li
                      | Nested lists:
                      ul
                        li are unaffected by this style
                        li will still show a bullet
                        li and have appropriate left margin
                    li This may still come in handy in some situations.
              .bd-example-snippet.bd-code-snippet
                .bd-example
                  ul.list-inline
                    li.list-inline-item This is a list item.
                    li.list-inline-item And another one.
                    li.list-inline-item But they&apos;re displayed inline.
          article#images.my-3
            .bd-heading.align-self-start.mt-5.mb-3.mt-xl-0.mb-xl-2
              h3 Images
              a.d-flex.align-items-center(href=baseUrl + 'ui/images.html') View Detailed Documentation
            div
              .card.mb-3
                .card-body.p-4.text-center
                  i.bi.bi-image-fill.display-4.text-primary.mb-3
                  h5 Comprehensive Image Guide
                  p.text-muted We have moved the detailed documentation for responsive images, thumbnails, and alignment to a dedicated page for better clarity.
                  a.btn.btn-primary.px-4(href=baseUrl + 'ui/images.html')
                    | Go to Images Documentation
                    i.bi.bi-arrow-right.ms-2
          article#tables.my-3
            .bd-heading.align-self-start.mt-5.mb-3.mt-xl-0.mb-xl-2
              h3 Tables
              a.d-flex.align-items-center(href='../content/tables/') Documentation
            div
